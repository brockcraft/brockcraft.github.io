# Notion integration (optional for local dev — falls back to src/data/work-fallback.json)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Optional: override default property names (must match your Notion database)
# NOTION_PROP_SLUG=Slug
# NOTION_PROP_TAGS=Tags
# NOTION_PROP_PUBLISHED=Published
# NOTION_PROP_SUMMARY=Summary
# NOTION_PROP_DATE=Date
# NOTION_PROP_COVER=Cover

# Legacy import (scripts/notion-import-legacy.ts) — optional
# NOTION_IMPORT_PUBLISHED=false   # default true; set false to create unpublished rows
# NOTION_IMPORT_SITE_ORIGIN=https://brockcraft.github.io  # used when building cover URLs in merge step
